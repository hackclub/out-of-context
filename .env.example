# Slack Credentials
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_OOC_CHANNEL_ID=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Database Configuration
DB_USER=user
DB_PASSWORD=password
DB_NAME=ooc_db
DB_PORT=5431

# Prisma Database URL (must match the config above)
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}?schema=public"

# Moderation Thresholds (Optional overrides)
APPROVED_POSTS_FOR_TRUST=14
MAX_EXPLICIT_REJECTIONS_FOR_TRUST=0
EXPLICIT_REJECTION_WINDOW_DAYS=30
EXPLICIT_REJECTIONS_BEFORE_BAN=3
DEFAULT_OOC_BAN_DAYS=7
COOLDOWN_SUBMISSIONS_LIMIT=5
COOLDOWN_WINDOW_MINUTES=60
COOLDOWN_DURATION_MINUTES=30
TRUSTED_REVIEW_ENABLED=true

# super admin

SLACK_SUPER_ADMIN_ID=

# helper bot

SLACK_HELPER_BOT_TOKEN=
SLACK_HELPER_BOT_MESSAGE="To submit to OOC, use the `Submit to OOC` message shortcut!"

SLACK_USER_TOKEN=

NODE_ENV=development
