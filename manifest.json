{
  "display_information": {
    "name": "Out of Context",
    "description": "Manage moderated submissions for the #out-of-context channel.",
    "background_color": "#2c0230"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "OOC Bot",
      "always_online": true
    },
    "shortcuts": [
      {
        "name": "Submit to #out-of-context",
        "type": "message",
        "callback_id": "submit_to_ooc",
        "description": "Submit this message for review to appear in #out-of-context"
      }
    ],
    "slash_commands": [
      {
        "command": "/b-status",
        "description": "Check your submission status and history.",
        "should_escape": false
      },
      {
        "command": "/b-delete",
        "description": "Delete a pending submission.",
        "usage_hint": "[submission_id]",
        "should_escape": false
      },
      {
        "command": "/b-mod-queue",
        "description": "View and manage the pending moderation queue.",
        "should_escape": false
      },
      {
        "command": "/b-grant-trust",
        "description": "Grant a user Trusted status (bypass queue).",
        "usage_hint": "@user",
        "should_escape": true
      },
      {
        "command": "/b-revoke-trust",
        "description": "Revoke a user's Trusted status.",
        "usage_hint": "@user",
        "should_escape": true
      },
      {
        "command": "/b-grant-admin",
        "description": "Grant a user Admin privileges.",
        "usage_hint": "@user",
        "should_escape": true
      },
      {
        "command": "/b-revoke-admin",
        "description": "Revoke a user's Admin privileges.",
        "usage_hint": "@user",
        "should_escape": true
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "user": [
        "chat:write"
      ],
      "bot": [
        "im:history",
        "chat:write",
        "chat:write.customize",
        "users:read",
        "channels:history",
        "channels:join",
        "groups:history",
        "mpim:history",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.im",
        "message.channels",
        "message.groups"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
