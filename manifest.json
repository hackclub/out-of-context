{
  "display_information": {
    "name": "Out of Context",
    "description": "Manage moderated submissions for the #out-of-context channel.",
    "background_color": "#2c0230"
  },
  "features": {
    "bot_user": {
      "display_name": "OOC Bot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/status",
        "description": "Check your submission status and history.",
        "should_escape": false
      },
      {
        "command": "/delete",
        "description": "Delete a pending submission.",
        "usage_hint": "[submission_id]",
        "should_escape": false
      },
      {
        "command": "/mod-queue",
        "description": "View and manage the pending moderation queue.",
        "should_escape": false
      },
      {
        "command": "/grant-trust",
        "description": "Grant a user Trusted status (bypass queue).",
        "usage_hint": "@user",
        "should_escape": false
      },
      {
        "command": "/revoke-trust",
        "description": "Revoke a user's Trusted status.",
        "usage_hint": "@user",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "im:history",
        "chat:write",
        "channels:history",
        "groups:history",
        "mpim:history",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
