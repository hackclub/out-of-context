{
  "name": "out-of-ontext",
  "version": "0.0.1",
  "description": "Out of Context (OOC)",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "prisma migrate deploy && node ./dist/app.js",
    "dev": "tsx watch app.ts",
    "postinstall": "prisma generate",
    "lint": "npx @biomejs/biome check *.ts src listeners tests",
    "lint:fix": "npx @biomejs/biome check --write *.ts listeners tests",
    "test": "npx prisma generate && npm run build && npm run lint && node --import tsx --test"
  },
  "license": "MIT",
  "keywords": [
    "slack",
    "bolt",
    "slackapi",
    "typescript"
  ],
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@slack/bolt": "^5.0.0",
    "dotenv": "~17.4.2",
    "dotenv-expand": "^13.0.0",
    "pg": "^8.21.0",
    "prisma": "^7.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
