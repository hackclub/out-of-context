{
  "display_information": {
    "name": "OOC Helper",
    "description": "Posts a prompt after each OOC submission to guide users on how to submit.",
    "background_color": "#2c0230"
  },
  "features": {
    "bot_user": {
      "display_name": "OOC Helper",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write"
      ]
    }
  },
  "settings": {
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
